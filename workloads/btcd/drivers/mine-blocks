#!/bin/sh
# Mine a random number (1-16) of regtest blocks on a randomly-chosen
# peer (btcd1 or btcd2). Both peers share the same --miningaddr (the
# btcd-launcher injects it on every node), so the coinbase always pays
# to the wallet's default-account address regardless of which side
# mines. Exercising both nodes as the producer also tests the relay
# path in both directions.
#
# Random bytes from /dev/urandom for the same reason as send-self —
# kernel RNG → deterministic across replays under bedrock.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

# Entropy is the deterministic, fuzzer-controlled /dev/urandom stream (bedrock
# serves it from a VMCALL), read once into a hex buffer; fz N returns
# byte N of it. The fuzzer steers driver parameters by mutating the
# bytes the VMCALL returns; replays are deterministic.
FZ=$(od -An -N64 -tx1 /dev/urandom | tr -d ' \n'); fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); echo $(( 0x${h:-0} )); }

host_byte=$(fz 0)
count_byte=$(fz 1)

if [ $((host_byte % 2)) -eq 0 ]; then
    host=btcd1
else
    host=btcd2
fi
n=$((count_byte % 16 + 1))

echo "mining $n block(s) on $host"
btcctl --regtest -u user -P password \
    --rpccert=/etc/bedrock/rpc.cert \
    --rpcserver="$host:18334" generate "$n"
