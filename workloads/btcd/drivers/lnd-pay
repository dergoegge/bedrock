#!/bin/sh
# Route a Lightning payment between two randomly-chosen lnd nodes: the receiver
# mints an invoice for a random amount (1,000-50,000 sat) and the sender pays
# it. With three nodes wired as a chain (lnd1<->lnd2<->lnd3), an lnd1<->lnd3
# pair forces a multi-hop route through lnd2 — exercising HTLC forwarding and
# route finding on top of the single-hop add/settle path. --force skips
# lncli's interactive confirm; --timeout caps a stuck attempt at 10s so a
# payment with no usable route (expected when the fuzzer closes channels)
# fails fast instead of holding the branch. Random bytes from /dev/urandom —
# deterministic across replays under bedrock.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

FZ="${1:-}"; fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); if [ ${#h} -eq 2 ]; then echo $((0x$h)); else od -An -N1 -tu1 /dev/urandom|tr -d ' \n'; fi; }
b1=$(fz 0)
b2=$(fz 1)
b3=$(fz 2)

i=$(( b1 % 3 ))
j=$(( (i + b2 % 2 + 1) % 3 ))            # distinct from i (offset 1 or 2)
src=$(echo "$NODES" | cut -d' ' -f$(( i + 1 )))
dst=$(echo "$NODES" | cut -d' ' -f$(( j + 1 )))
amt=$(( b3 * 192 + 1000 ))               # 1,000 .. ~50,000 sat

echo "paying $amt sat from $src to $dst"
pay_req=$($LNCLI --rpcserver="$dst:10009" addinvoice --amt "$amt" \
    | sed -n 's/.*"payment_request":[[:space:]]*"\([a-zA-Z0-9]*\)".*/\1/p' | head -n1)
if [ -z "$pay_req" ]; then
    echo "failed to create invoice on $dst"
    exit 0
fi
$LNCLI --rpcserver="$src:10009" payinvoice --force --timeout 10s "$pay_req"
