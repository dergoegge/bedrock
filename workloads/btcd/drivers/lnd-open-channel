#!/bin/sh
# Open a Lightning channel between two randomly-chosen lnd nodes with a random
# local amount (~0.005-0.02 BTC). With three nodes this can add a direct
# lnd1<->lnd3 channel (a shortcut across the lnd1<->lnd2<->lnd3 chain) or
# thicken an existing leg. Only initiated here: the funding tx is broadcast to
# the mempool and the channel stays pending until the mine-blocks driver mines
# it in (defaultchanconfs=1). Re-connects first since the peer link may have
# dropped. Random bytes from /dev/urandom — deterministic across replays under
# bedrock.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

# Entropy is the deterministic, fuzzer-controlled /dev/urandom stream (bedrock
# serves it from a VMCALL), read once into a hex buffer; fz N returns
# byte N of it. The fuzzer steers driver parameters by mutating the
# bytes the VMCALL returns; replays are deterministic.
FZ=$(od -An -N64 -tx1 /dev/urandom | tr -d ' \n'); fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); echo $(( 0x${h:-0} )); }
b1=$(fz 0)
b2=$(fz 1)
amt_byte=$(fz 2)
push_byte=$(fz 3)

i=$(( b1 % 3 ))
j=$(( (i + b2 % 2 + 1) % 3 ))            # distinct from i
src=$(echo "$NODES" | cut -d' ' -f$(( i + 1 )))
dst=$(echo "$NODES" | cut -d' ' -f$(( j + 1 )))

# Span the whole openable range: below the dust/min-channel floor (should be
# rejected), the normal band, and up near the non-wumbo max (~16.7M sat). The
# fuzzer picks which regime via amt_byte; boundary funding values are a classic
# place for off-by-one / reserve-calculation bugs.
case $(( amt_byte % 4 )) in
  0) local_amt=$(( amt_byte + 1 )) ;;             # 1..256 sat (under minimum)
  1) local_amt=$(( amt_byte * 6000 + 20000 )) ;;  # ~20k..1.55M sat
  2) local_amt=$(( amt_byte * 60000 + 100000 )) ;;# ~100k..15.4M sat
  3) local_amt=16777215 ;;                        # max non-wumbo channel
esac
# Sometimes push part of the local balance to the remote at open. push must be
# < local_amt or lnd rejects; we let the fuzzer hit that boundary too.
push_amt=$(( push_byte * local_amt / 256 ))

dst_pk=$($LNCLI --rpcserver="$dst:10009" getinfo \
    | sed -n 's/.*"identity_pubkey":[[:space:]]*"\([0-9a-f]*\)".*/\1/p' | head -n1)
[ -z "$dst_pk" ] && { echo "no pubkey for $dst"; exit 0; }

echo "opening channel $src -> $dst local=$local_amt push=$push_amt sat"
$LNCLI --rpcserver="$src:10009" connect "$dst_pk@$dst:9735" 2>/dev/null || true
$LNCLI --rpcserver="$src:10009" openchannel --node_key "$dst_pk" \
    --local_amt "$local_amt" --push_amt "$push_amt" || true
