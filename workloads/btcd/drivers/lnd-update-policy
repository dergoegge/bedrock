#!/bin/sh
# Randomly update the routing policy (base fee, fee rate, CLTV delta) across a
# chosen node's channels. With no --chan_point the change applies to every
# channel, and each emits a channel_update that gossips to the other node —
# exercising the gossip / policy-propagation path. Once it settles both nodes
# should converge on the new policy, so this doubles as a divergence probe.
# Random bytes from /dev/urandom — deterministic across replays under bedrock.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

FZ="${1:-}"; fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); if [ ${#h} -eq 2 ]; then echo $((0x$h)); else od -An -N1 -tu1 /dev/urandom|tr -d ' \n'; fi; }
node_byte=$(fz 0)
base_byte=$(fz 1)
rate_byte=$(fz 2)
tld_byte=$(fz 3)

node=$(echo "$NODES" | cut -d' ' -f$(( node_byte % 3 + 1 )))
base_fee=$((base_byte * 100000))    # 0 .. ~25.5M msat (wide, incl. 0)
fee_ppm=$((rate_byte * 100000))     # 0 .. ~25.5M ppm (incl. 0 and absurd)
# Span the cltv-delta range across and past lnd's uint16 channel-update field
# (0, below-minimum, normal, and >65535 which the RPC takes as uint32 — a
# truncation / validation boundary worth probing).
case $(( tld_byte % 4 )) in
  0) time_lock=0 ;;
  1) time_lock=$(( tld_byte % 18 )) ;;       # below minimum CLTV delta
  2) time_lock=$(( tld_byte % 100 + 18 )) ;; # normal band
  3) time_lock=$(( 65535 + tld_byte )) ;;    # past uint16
esac

echo "updating policy on $node: base_fee=${base_fee}msat fee_ppm=${fee_ppm} time_lock_delta=${time_lock}"
$LNCLI --rpcserver="$node:10009" updatechanpolicy \
    --base_fee_msat "$base_fee" --fee_rate_ppm "$fee_ppm" --time_lock_delta "$time_lock" || true
