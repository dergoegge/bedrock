#!/bin/sh
# Randomly update the routing policy (base fee, fee rate, CLTV delta) across a
# chosen node's channels. With no --chan_point the change applies to every
# channel, and each emits a channel_update that gossips to the other node —
# exercising the gossip / policy-propagation path. Once it settles both nodes
# should converge on the new policy, so this doubles as a divergence probe.
# Random bytes from /dev/urandom — deterministic across replays under bedrock.
set -eu
LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

rand_bytes=$(od -An -N4 -tu1 /dev/urandom | tr -s ' ' '\n' | grep -v '^$')
node_byte=$(echo "$rand_bytes" | sed -n 1p)
base_byte=$(echo "$rand_bytes" | sed -n 2p)
rate_byte=$(echo "$rand_bytes" | sed -n 3p)
tld_byte=$(echo  "$rand_bytes" | sed -n 4p)

node=$(echo "$NODES" | cut -d' ' -f$(( node_byte % 3 + 1 )))
base_fee=$((base_byte * 10))        # 0 .. 2550 msat
fee_ppm=$((rate_byte * 20 + 1))     # 1 .. 5101 ppm
time_lock=$((tld_byte % 100 + 18))  # 18 .. 117 (>= lnd's minimum CLTV delta)

echo "updating policy on $node: base_fee=${base_fee}msat fee_ppm=${fee_ppm} time_lock_delta=${time_lock}"
$LNCLI --rpcserver="$node:10009" updatechanpolicy \
    --base_fee_msat "$base_fee" --fee_rate_ppm "$fee_ppm" --time_lock_delta "$time_lock"
