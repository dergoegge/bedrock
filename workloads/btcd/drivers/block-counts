#!/bin/sh
# Report block height from both btcd peers and the wallet's chain view.
# A deterministic run pins the three numbers together once peering has
# settled; divergence shows up as a height gap.

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

BCTL_N="btcctl --regtest -u user -P password --rpccert=/etc/bedrock/rpc.cert"
BCTL_W="btcctl --regtest --wallet -u user -P password --rpccert=/etc/bedrock/rpc.cert --rpcserver=btcwallet:18332"
printf 'btcd1:    '; $BCTL_N --rpcserver=btcd1:18334 getblockcount
printf 'btcd2:    '; $BCTL_N --rpcserver=btcd2:18334 getblockcount
printf 'wallet:   '; $BCTL_W getblockcount
