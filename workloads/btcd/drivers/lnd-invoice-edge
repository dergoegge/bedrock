#!/bin/sh
# Mint invoices across the edge of lnd's invoice parameter space (amount,
# expiry, final-cltv delta), then immediately decode the resulting payment
# request back through `decodepayreq`. This exercises both the invoice
# registry / creation path and the zpay32 bech32+TLV decoder on lnd-generated
# requests with unusual fields. Generic harness: the fuzzer steers the field
# values via the deterministic /dev/urandom stream; nothing here is rigged.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

# Entropy is the deterministic, fuzzer-controlled /dev/urandom stream (bedrock
# serves it from trapped RDRAND), read once into a hex buffer; fz N returns
# byte N of it. The fuzzer steers driver parameters by mutating the RDRAND
# values behind these bytes; replays are deterministic.
FZ=$(od -An -N64 -tx1 /dev/urandom | tr -d ' \n'); fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); echo $(( 0x${h:-0} )); }
nb=$(fz 0)
a0=$(fz 1)
a1=$(fz 2)
expb=$(fz 3)
cltvb=$(fz 4)
shape=$(fz 5)

node=$(echo "$NODES" | cut -d' ' -f$(( nb % 3 + 1 )))
base=$(( a1 * 256 + a0 ))

case $(( shape % 4 )) in
  0) amt=0 ;;                          # any-amount invoice
  1) amt=$(( base + 1 )) ;;            # small
  2) amt=$(( base * 100000 + 1 )) ;;   # large
  3) amt=$(( 2100000000000000 )) ;;    # ~21M BTC in sat (max money)
esac

expiry=$(( expb * expb ))             # 0 .. ~65k seconds, includes 0
cltv=$(( cltvb ))                     # 0 .. 255 final cltv delta (0 = use default)

echo "addinvoice on $node amt=$amt expiry=$expiry cltv=$cltv"
# Try with the cltv-delta flag (present on newer lnd); fall back to the
# guaranteed flags so the driver still produces an invoice on older builds.
extract='s/.*"payment_request":[[:space:]]*"\([a-zA-Z0-9]*\)".*/\1/p'
pr=$($LNCLI --rpcserver="$node:10009" addinvoice \
        --amt "$amt" --expiry "$expiry" --cltv_expiry_delta "$cltv" 2>/dev/null \
    | sed -n "$extract" | head -n1)
if [ -z "$pr" ]; then
    pr=$($LNCLI --rpcserver="$node:10009" addinvoice \
            --amt "$amt" --expiry "$expiry" 2>/dev/null \
        | sed -n "$extract" | head -n1)
fi
if [ -z "$pr" ]; then
    echo "no invoice produced (amt=$amt expiry=$expiry cltv=$cltv)"
    exit 0
fi
echo "decodepayreq on $node"
$LNCLI --rpcserver="$node:10009" decodepayreq "$pr" >/dev/null || true
