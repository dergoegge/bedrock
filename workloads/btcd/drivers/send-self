#!/bin/sh
# Send a random number (1-5) of transactions to freshly-generated wallet
# addresses, each carrying a random amount (1-10 BTC). Exercises tx
# construction, signing, mempool insertion, and p2p relay across a
# burst rather than a single tx; does NOT mine to confirm — leaving
# txs in the mempool is the point (mine-blocks is a separate driver,
# and the fuzzer can interleave them to test mempool drain / batched
# confirmation paths).
#
# Random bytes from /dev/urandom rather than $RANDOM or awk's rand()
# so the values are rooted in the guest kernel's RNG pool, which is
# served by bedrock's deterministic get-random VMCALL — the
# choices end up deterministic across replay runs of the same input
# sequence.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

# Entropy is the deterministic, fuzzer-controlled /dev/urandom stream (bedrock
# serves it from a VMCALL), read once into a hex buffer; fz N returns
# byte N of it. The fuzzer steers driver parameters by mutating the
# bytes the VMCALL returns; replays are deterministic.
FZ=$(od -An -N64 -tx1 /dev/urandom | tr -d ' \n'); fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); echo $(( 0x${h:-0} )); }

BCTL_W="btcctl --regtest --wallet -u user -P password --rpccert=/etc/bedrock/rpc.cert --rpcserver=btcwallet:18332"

$BCTL_W walletpassphrase password 86400 >/dev/null

# Byte 0 decides the tx count; per-tx amount bytes come from offsets 2*i+2.
count_byte=$(fz 0)

count=$((count_byte % 12 + 1))
echo "sending $count tx(s)"

i=0
while [ $i -lt $count ]; do
    # Two fuzzer bytes per tx (offsets 2*i+2, 2*i+3) so amounts vary
    # independently. Span dust through large amounts so the fuzzer can hit
    # relay/dust/fee-estimation edges as well as the common case; over-balance
    # sends are rejected and benign.
    a0=$(fz $((2*i + 2)))
    a1=$(fz $((2*i + 3)))
    case $(( (a1 + i) % 4 )) in
      0) amount="0.00000$(printf '%03d' $(( a0 % 1000 )))" ;;  # ~dust
      1) amount="$(( a0 % 10 + 1 )).0" ;;                      # 1..10 BTC
      2) amount="$(( a0 % 100 + 1 )).$(printf '%08d' $(( (a0*7) % 100000000 )))" ;;
      3) amount="0.$(printf '%08d' $(( (a0*131) % 100000000 )))" ;;
    esac
    addr=$($BCTL_W getnewaddress)
    txid=$($BCTL_W sendtoaddress "$addr" "$amount" 2>/dev/null || echo "")
    echo "  [$((i+1))/$count] $amount -> $addr  (${txid:-rejected})"
    i=$((i + 1))
done
