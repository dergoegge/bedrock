#!/bin/sh
# Adversarial Lightning payment driver. Unlike lnd-pay (which mints a valid
# invoice for an in-capacity amount and pays it), this fires payments across
# the whole edge of the parameter space the fuzzer can reach: amounts that may
# exceed channel capacity, near-zero / zero amounts, very large amounts, and
# fee / cltv / timeout limits pushed to their boundaries. Each leg is a normal
# RPC call — nothing is rigged to fail or to crash; the point is to let the
# coverage-guided fuzzer steer lnd's pathfinding, HTLC-add, and payment-state
# machinery (router, htlcswitch, missioncontrol) into corners the conservative
# drivers never reach. All randomness is /dev/urandom, which bedrock serves
# deterministically from trapped RDRAND, so a crashing sequence replays.
set -eu

# Never exit non-zero: a fuzzer-invoked driver exec dying with a bad code
# would trip the "exec exit code is zero" assertion and be flagged as a bug.
# Expected RPC/edge-input failures (a partitioned peer, a rejected blob) are
# handled by forcing a clean exit on every path out of the script.
trap 'exit 0' EXIT

LNCLI="lncli --network=regtest --no-macaroons --tlscertpath=/etc/bedrock/rpc.cert"
NODES="lnd1 lnd2 lnd3"

FZ="${1:-}"; fz(){ o=$(( ${1:-0} * 2 )); h=$(printf %s "$FZ"|cut -c$((o+1))-$((o+2))); if [ ${#h} -eq 2 ]; then echo $((0x$h)); else od -An -N1 -tu1 /dev/urandom|tr -d ' \n'; fi; }
b1=$(fz 0)
b2=$(fz 1)
amt_lo=$(fz 2)
amt_hi=$(fz 3)
shape=$(fz 4)
knob=$(fz 5)

i=$(( b1 % 3 ))
j=$(( (i + b2 % 2 + 1) % 3 ))            # distinct from i
src=$(echo "$NODES" | cut -d' ' -f$(( i + 1 )))
dst=$(echo "$NODES" | cut -d' ' -f$(( j + 1 )))

# Compose a 16-bit base amount, then map it onto a wide regime chosen by the
# shape byte: dust/zero, in-range, channel-capacity-ish, or absurdly large.
base=$(( amt_hi * 256 + amt_lo ))
case $(( shape % 5 )) in
  0) amt=$(( base % 4 )) ;;                 # 0..3 sat (incl. zero)
  1) amt=$(( base + 1 )) ;;                 # ~1..65k sat, mostly routable
  2) amt=$(( base * 64 + 1 )) ;;            # up to ~4.2M sat, near/over capacity
  3) amt=$(( base * 100000 + 1 )) ;;        # huge, far over any channel
  4) amt=$(( 4294967295 - base )) ;;        # near uint32 max sat
esac

# A receiver-side invoice (normal path) most of the time, but sometimes pay a
# spontaneous keysend to the destination's raw pubkey (no invoice), which
# exercises a different add path and can route to a node with no inbound.
fee_limit=$(( knob % 4 ))                   # 0..3 sat fee cap (0 = no headroom)
if [ $(( knob % 3 )) -eq 0 ]; then
    dst_pk=$($LNCLI --rpcserver="$dst:10009" getinfo \
        | sed -n 's/.*"identity_pubkey":[[:space:]]*"\([0-9a-f]*\)".*/\1/p' | head -n1)
    [ -z "$dst_pk" ] && { echo "no pubkey for $dst"; exit 0; }
    echo "keysend $amt sat $src -> $dst (fee_limit=$fee_limit)"
    $LNCLI --rpcserver="$src:10009" sendpayment --keysend --dest "$dst_pk" \
        --amt "$amt" --fee_limit "$fee_limit" --force --timeout 8s || true
    exit 0
fi

echo "pay $amt sat $src -> $dst (fee_limit=$fee_limit)"
pay_req=$($LNCLI --rpcserver="$dst:10009" addinvoice --amt "$amt" \
    | sed -n 's/.*"payment_request":[[:space:]]*"\([a-zA-Z0-9]*\)".*/\1/p' | head -n1)
if [ -z "$pay_req" ]; then
    echo "no invoice from $dst for amt=$amt"
    exit 0
fi
$LNCLI --rpcserver="$src:10009" payinvoice --force --timeout 8s \
    --fee_limit "$fee_limit" "$pay_req" || true
