#!/usr/bin/dash
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev

# Redirect all output to console
exec >/dev/console 2>&1

# Set up loopback
ip link set lo up

# Verify networking over loopback
echo "=== Network Configuration ==="
ip addr show lo
echo ""
echo "=== Testing loopback connectivity ==="
if ping -c 1 -W 2 127.0.0.1 >/dev/null 2>&1; then
    echo "Loopback ping: OK"
else
    echo "Loopback ping: FAILED"
fi
echo "=== Network test complete ==="
echo ""

exec setsid sh -c 'exec sh </dev/console >/dev/console 2>&1'
